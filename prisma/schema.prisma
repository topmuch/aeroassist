generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── USER MANAGEMENT ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  name          String
  role          String    @default("traveler") // traveler, partner, admin, superadmin
  avatar        String?
  language      String    @default("fr")
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]
  reservations  Reservation[]
  auditLogs     AuditLog[]
  ownedKbEntries KnowledgeBaseEntry[] @relation("KbOwner")
}

// ─── WHATSAPP CONVERSATIONS ────────────────────────────────────

model Conversation {
  id           String    @id @default(cuid())
  whatsappId   String    @unique
  userId       String?
  status       String    @default("active") // active, escalated, closed
  language     String    @default("fr")
  lastMessage  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages     Message[]
  reservations Reservation[]
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  direction      String    // inbound, outbound
  content        String
  messageType    String    @default("text") // text, image, interactive, location, document
  intent         String?
  confidence     Float?
  isRead         Boolean   @default(false)
  createdAt      DateTime  @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([intent])
  @@index([createdAt, intent])
}

// ─── KNOWLEDGE BASE & FAQ ──────────────────────────────────────

model KnowledgeBaseEntry {
  id          String   @id @default(cuid())
  title       String
  content     String
  source      String?  // URL or file reference
  category    String   @default("general") // flights, services, restaurants, shops, transport, general
  status      String   @default("draft")   // draft, validated, published, archived
  version     Int      @default(1)
  chunkCount  Int      @default(1)
  ownerId     String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User?    @relation("KbOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}

// ─── FLIGHTS ───────────────────────────────────────────────────

model Flight {
  id            String   @id @default(cuid())
  flightNumber  String
  airline       String
  departure     String   // airport code
  arrival       String   // airport code
  scheduledDep  DateTime
  scheduledArr  DateTime
  actualDep     DateTime?
  actualArr     DateTime?
  status        String   @default("scheduled") // scheduled, delayed, cancelled, boarding, departed, arrived
  gate          String?
  terminal      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── RESERVATIONS ──────────────────────────────────────────────

model Reservation {
  id            String   @id @default(cuid())
  userId        String?
  type          String   // vip_lounge, hotel, car_rental, duty_free
  status        String   @default("pending") // pending, confirmed, cancelled, completed
  reference     String   @unique
  details       String   // JSON string with reservation specifics
  totalAmount   Float    @default(0)
  currency      String   @default("EUR")
  paymentStatus String   @default("pending") // pending, paid, refunded
  paidAt        DateTime?
  conversationId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversation  Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([paymentStatus])
  @@index([createdAt, paymentStatus])
}

// ─── SYSTEM MODULES ────────────────────────────────────────────

model Module {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(false)
  config      String   // JSON configuration
  partnerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SYSTEM CONFIGURATION ──────────────────────────────────────

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string") // string, number, boolean, json
  updatedAt DateTime @updatedAt
}

// ─── AUDIT LOGS ────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  details   String?  // JSON string
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── ANALYTICS ─────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String   // message_sent, message_received, intent_detected, reservation_created, escalation
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
}

// ─── WHATSAPP CONTACTS (OpenBSP) ────────────────────────────────

model WhatsAppContact {
  id              String    @id @default(cuid())
  phoneNumber     String    @unique            // E.164 format: +33612345678
  waId            String?                      // WhatsApp internal ID
  pushName        String?                      // Name set by user in WhatsApp
  language        String    @default("fr")
  isOptIn         Boolean   @default(true)     // RGPD opt-in consent
  isBlacklisted   Boolean   @default(false)    // Blocked users
  lastSeenAt      DateTime?
  messageCount    Int       @default(0)
  optInDate       DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── WHATSAPP TEMPLATES (OpenBSP) ──────────────────────────────

model WhatsAppTemplate {
  id            String   @id @default(cuid())
  name          String   @unique              // Template name in Meta
  displayName   String                        // Human-readable name
  category      String                        // MARKETING, UTILITY, AUTHENTICATION
  language      String   @default("fr")
  status        String   @default("draft")    // draft, submitted, approved, rejected
  metaTemplateId String?                      // Template ID from Meta
  components    String   @default("[]")       // JSON: template components
  bodyText      String?                      // Template body text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
