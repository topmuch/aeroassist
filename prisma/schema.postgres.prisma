generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = ["vector"]
}

// ─── USER MANAGEMENT ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @db.VarChar(20)
  name          String    @db.VarChar(255)
  role          String    @default("traveler") @db.VarChar(20) // traveler, partner, admin, superadmin
  avatar        String?   @db.VarChar(500)
  language      String    @default("fr") @db.VarChar(5)
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]
  reservations  Reservation[]
  auditLogs     AuditLog[]
  ownedKbEntries KnowledgeBaseEntry[] @relation("KbOwner")
  @@index([email])
  @@map("users")
}

// ─── WHATSAPP CONVERSATIONS ────────────────────────────────────

model Conversation {
  id           String    @id @default(cuid())
  whatsappId   String    @unique @db.VarChar(30)
  userId       String?
  status       String    @default("active") @db.VarChar(20) // active, escalated, closed
  language     String    @default("fr") @db.VarChar(5)
  lastMessage  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages     Message[]
  reservations Reservation[]
  @@index([status, lastMessage])
  @@map("conversations")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  direction      String    @db.VarChar(10) // inbound, outbound
  content        String    @db.Text
  messageType    String    @default("text") @db.VarChar(20) // text, image, interactive, location, document
  intent         String?   @db.VarChar(100)
  confidence     Float?
  isRead         Boolean   @default(false)
  createdAt      DateTime  @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── KNOWLEDGE BASE & FAQ (with pgvector embeddings) ───────────

model KnowledgeBaseEntry {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(500)
  content     String   @db.Text
  source      String?  @db.VarChar(500) // URL or file reference
  category    String   @default("general") @db.VarChar(50) // flights, services, restaurants, shops, transport, general
  status      String   @default("draft") @db.VarChar(20)   // draft, validated, published, archived
  version     Int      @default(1)
  chunkCount  Int      @default(1)
  ownerId     String?
  embedding   Unsupported("vector(384)")? // pgvector embedding column for RAG
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User?    @relation("KbOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  @@index([category, status])
  @@index([status, updatedAt])
  @@map("knowledge_base_entries")
}

// ─── FLIGHTS ───────────────────────────────────────────────────

model Flight {
  id            String   @id @default(cuid())
  flightNumber  String   @db.VarChar(10)
  airline       String   @db.VarChar(100)
  departure     String   @db.VarChar(3) // airport code
  arrival       String   @db.VarChar(3) // airport code
  scheduledDep  DateTime
  scheduledArr  DateTime
  actualDep     DateTime?
  actualArr     DateTime?
  status        String   @default("scheduled") @db.VarChar(20) // scheduled, delayed, cancelled, boarding, departed, arrived
  gate          String?  @db.VarChar(10)
  terminal      String?  @db.VarChar(10)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([flightNumber])
  @@index([status, scheduledDep])
  @@unique([flightNumber, scheduledDep])
  @@map("flights")
}

// ─── RESERVATIONS ──────────────────────────────────────────────

model Reservation {
  id            String   @id @default(cuid())
  userId        String?
  type          String   @db.VarChar(50) // vip_lounge, hotel, car_rental, duty_free
  status        String   @default("pending") @db.VarChar(20) // pending, confirmed, cancelled, completed
  reference     String   @unique @db.VarChar(20)
  details       String   @db.Text // JSON string with reservation specifics
  totalAmount   Float
  currency      String   @default("EUR") @db.VarChar(3)
  paymentStatus String   @default("pending") @db.VarChar(20) // pending, paid, refunded
  paidAt        DateTime?
  conversationId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversation  Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  @@index([userId, status])
  @@index([status, createdAt])
  @@map("reservations")
}

// ─── SYSTEM MODULES ────────────────────────────────────────────

model Module {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(false)
  config      String   @db.Text // JSON configuration
  partnerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("modules")
}

// ─── SYSTEM CONFIGURATION ──────────────────────────────────────

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique @db.VarChar(100)
  value String @db.Text
  type  String @default("string") @db.VarChar(20) // string, number, boolean, json
  updatedAt DateTime @updatedAt
  @@map("system_configs")
}

// ─── AUDIT LOGS ────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   @db.VarChar(100)
  resource  String   @db.VarChar(100)
  details   String?  @db.Text // JSON string
  ipAddress String?  @db.VarChar(45)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─── ANALYTICS ─────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String   @db.VarChar(50) // message_sent, message_received, intent_detected, reservation_created, escalation
  metadata  String?  @db.Text // JSON string
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─── WHATSAPP CONTACTS (OpenBSP) ────────────────────────────────

model WhatsAppContact {
  id              String    @id @default(cuid())
  phoneNumber     String    @unique @db.VarChar(20) // E.164 format: +33612345678
  waId            String?   @db.VarChar(50) // WhatsApp internal ID
  pushName        String?   @db.VarChar(255) // Name set by user in WhatsApp
  language        String    @default("fr") @db.VarChar(5)
  isOptIn         Boolean   @default(true) // RGPD opt-in consent
  isBlacklisted   Boolean   @default(false) // Blocked users
  lastSeenAt      DateTime?
  messageCount    Int       @default(0)
  optInDate       DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isBlacklisted, lastSeenAt])
  @@index([phoneNumber])
  @@map("whatsapp_contacts")
}

// ─── WHATSAPP TEMPLATES (OpenBSP) ──────────────────────────────

model WhatsAppTemplate {
  id            String   @id @default(cuid())
  name          String   @unique @db.VarChar(100) // Template name in Meta
  displayName   String   @db.VarChar(255) // Human-readable name
  category      String   @db.VarChar(50) // MARKETING, UTILITY, AUTHENTICATION
  language      String   @default("fr") @db.VarChar(5)
  status        String   @default("draft") @db.VarChar(20) // draft, submitted, approved, rejected
  metaTemplateId String?  @db.VarChar(100) // Template ID from Meta
  components    String   @default("[]") @db.Text // JSON: template components
  bodyText      String?  @db.Text // Template body text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, category])
  @@map("whatsapp_templates")
}
